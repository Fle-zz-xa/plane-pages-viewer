diff --git a/apps/web/core/components/rivetta/pipeline-board.tsx b/apps/web/core/components/rivetta/pipeline-board.tsx
new file mode 100644
index 0000000..ac17433
--- /dev/null
+++ b/apps/web/core/components/rivetta/pipeline-board.tsx
@@ -0,0 +1,156 @@
+import { observer } from "mobx-react";
+import { useNavigate } from "react-router";
+import { ChevronRight, ChevronDown } from "lucide-react";
+import type { IBaseLayoutsKanbanItem, IBaseLayoutsBaseGroup } from "@plane/types";
+import { cn } from "@plane/utils";
+import { TOAST_TYPE, setToast } from "@plane/propel/toast";
+import { Logo } from "@plane/propel/emoji-icon-picker";
+import { BaseKanbanLayout } from "@/components/base-layouts/kanban/layout";
+import {
+  parsePhase, encodePhase, stripPhaseMarker, PHASES, PHASE_ORDER, type ProjectPhase,
+} from "@/helpers/rivetta/phase";
+import { useProject } from "@/hooks/store/use-project";
+
+// Extend the kanban item with the fields we need
+interface PipelineProjectItem extends IBaseLayoutsKanbanItem {
+  id: string;
+  name: string;
+  identifier: string;
+  description: string;
+  logo_props: unknown;
+  member_role: unknown;
+}
+
+const BOARD_PHASES: ProjectPhase[] = PHASE_ORDER.filter((p) => p !== "archived");
+
+interface Props {
+  workspaceSlug: string;
+}
+
+export const RivettaPipelineBoard = observer(function RivettaPipelineBoard({ workspaceSlug }: Props) {
+  const navigate = useNavigate();
+  const { joinedProjectIds, getPartialProjectById, updateProject } = useProject();
+
+  // Build items map
+  const itemsMap: Record<string, PipelineProjectItem> = {};
+  const groupedIds: Record<string, string[]> = Object.fromEntries(BOARD_PHASES.map((p) => [p, []]));
+
+  (joinedProjectIds ?? []).forEach((id) => {
+    const p = getPartialProjectById(id);
+    if (!p) return;
+    const phase = parsePhase(p.description ?? "");
+    if (phase === "archived") return;
+    itemsMap[id] = {
+      id,
+      name: p.name,
+      identifier: p.identifier,
+      description: p.description ?? "",
+      logo_props: p.logo_props,
+      member_role: p.member_role,
+    };
+    if (groupedIds[phase]) groupedIds[phase].push(id);
+  });
+
+  const groups: IBaseLayoutsBaseGroup[] = BOARD_PHASES.map((phase) => ({
+    id: phase,
+    name: PHASES[phase].label,
+    count: groupedIds[phase]?.length ?? 0,
+  }));
+
+  const handleDrop = async (
+    sourceId: string,
+    _destinationId: string | null,
+    sourceGroupId: string,
+    destinationGroupId: string
+  ) => {
+    if (sourceGroupId === destinationGroupId) return;
+    const targetPhase = destinationGroupId as ProjectPhase;
+    if (targetPhase === "production") {
+      setToast({ type: TOAST_TYPE.INFO, title: "Handoff vereist", message: "Gebruik de fase-chip om naar Productie over te gaan." });
+      return;
+    }
+    try {
+      const project = getPartialProjectById(sourceId);
+      if (!project) return;
+      const newDesc = encodePhase(targetPhase, stripPhaseMarker(project.description ?? ""));
+      await updateProject(workspaceSlug, sourceId, { description: newDesc });
+      setToast({ type: TOAST_TYPE.SUCCESS, title: "Fase bijgewerkt", message: PHASES[targetPhase].label });
+    } catch {
+      setToast({ type: TOAST_TYPE.ERROR, title: "Fout", message: "Fase-overgang mislukt" });
+    }
+  };
+
+  const renderGroupHeader = ({
+    group,
+    itemCount,
+    isCollapsed,
+    onToggleGroup,
+  }: {
+    group: IBaseLayoutsBaseGroup;
+    itemCount: number;
+    isCollapsed: boolean;
+    onToggleGroup: (id: string) => void;
+  }) => {
+    const phase = group.id as ProjectPhase;
+    const cfg = PHASES[phase];
+    return (
+      <button
+        onClick={() => onToggleGroup(group.id)}
+        className="flex w-full items-center gap-2 px-2 py-1.5"
+      >
+        <span className={cn("h-2 w-2 rounded-full shrink-0", cfg.dotClass)} />
+        <span className={cn("text-11 font-semibold flex-1 text-left truncate", cfg.textClass)}>
+          {cfg.shortLabel}
+        </span>
+        <span className="text-11 text-placeholder tabular-nums">{itemCount}</span>
+        {isCollapsed
+          ? <ChevronRight className="h-3.5 w-3.5 text-placeholder" />
+          : <ChevronDown className="h-3.5 w-3.5 text-placeholder" />
+        }
+      </button>
+    );
+  };
+
+  const renderItem = (item: PipelineProjectItem) => {
+    const isMember = !!item.member_role;
+    return (
+      <div
+        onClick={() => isMember && navigate(`/${workspaceSlug}/projects/${item.id}/issues`)}
+        className={cn(
+          "flex flex-col gap-2 rounded-lg border border-subtle bg-layer-2 p-3 transition-all hover:border-strong hover:shadow-raised-100",
+          isMember ? "cursor-pointer" : "cursor-default opacity-70"
+        )}
+      >
+        <div className="flex items-start gap-2">
+          <div className="mt-0.5 flex h-6 w-6 shrink-0 items-center justify-center rounded-md bg-layer-3">
+            <Logo logo={item.logo_props as any} size={12} />
+          </div>
+          <div className="min-w-0 flex-1">
+            <p className="truncate text-13 font-medium text-primary">{item.name}</p>
+            <p className="text-11 text-placeholder">{item.identifier}</p>
+          </div>
+        </div>
+        {stripPhaseMarker(item.description).trim() && (
+          <p className="line-clamp-2 text-11 text-tertiary">
+            {stripPhaseMarker(item.description)}
+          </p>
+        )}
+      </div>
+    );
+  };
+
+  return (
+    <BaseKanbanLayout
+      items={itemsMap}
+      groups={groups}
+      groupedItemIds={groupedIds}
+      renderItem={renderItem}
+      renderGroupHeader={renderGroupHeader}
+      enableDragDrop
+      onDrop={handleDrop}
+      showEmptyGroups
+      className="h-full"
+      groupClassName="w-64 shrink-0"
+    />
+  );
+});
