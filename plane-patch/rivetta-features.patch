@@ -0,0 +1,144 @@
+import { observer } from "mobx-react";
+import { useParams } from "next/navigation";
+import { useState } from "react";
+import { Package, ChevronRight, Loader2, Search } from "lucide-react";
+import { TOAST_TYPE, setToast } from "@plane/propel/toast";
+import { parsePhase, encodePhase, stripPhaseMarker, PHASES } from "@/helpers/rivetta/phase";
+import { useProject } from "@/hooks/store/use-project";
+import { RivettaPhaseTimeline } from "@/components/rivetta/phase-badge";
+import { renderFormattedDate } from "@plane/utils";
+
+const VaultPage = observer(function VaultPage() {
+  const { workspaceSlug } = useParams<{ workspaceSlug: string }>();
+  const [query, setQuery] = useState("");
+  const [advancing, setAdvancing] = useState<string | null>(null);
+
+  const { joinedProjectIds, getPartialProjectById, updateProject } = useProject();
+
+  const allProjects = (joinedProjectIds ?? [])
+    .map((id) => getPartialProjectById(id))
+    .filter(Boolean);
+
+  const vaultProjects = allProjects.filter(
+    (p) => parsePhase(p!.description ?? "") === "vault"
+  );
+
+  const filtered = query.trim()
+    ? vaultProjects.filter(
+        (p) =>
+          p!.name.toLowerCase().includes(query.toLowerCase()) ||
+          stripPhaseMarker(p!.description ?? "").toLowerCase().includes(query.toLowerCase())
+      )
+    : vaultProjects;
+
+  const handleStartDesign = async (projectId: string, projectName: string, description: string) => {
+    if (!workspaceSlug) return;
+    if (!confirm(`"${projectName}" starten met Sample 1?`)) return;
+    setAdvancing(projectId);
+    try {
+      const newDesc = encodePhase("design_s1", stripPhaseMarker(description));
+      await updateProject(workspaceSlug, projectId, { description: newDesc });
+      setToast({ type: TOAST_TYPE.SUCCESS, title: "Fase bijgewerkt", message: `${projectName} staat nu in Design — Sample 1` });
+    } catch {
+      setToast({ type: TOAST_TYPE.ERROR, title: "Fout", message: "Fase-overgang mislukt" });
+    } finally {
+      setAdvancing(null);
+    }
+  };
+
+  return (
+    <div className="h-full flex flex-col">
+      {/* Header */}
+      <div className="flex items-center justify-between px-6 py-4 border-b border-gray-200 shrink-0">
+        <div className="flex items-center gap-3">
+          <div className="w-8 h-8 bg-gray-100 rounded-lg flex items-center justify-center">
+            <Package className="w-4 h-4 text-gray-600" />
+          </div>
+          <div>
+            <h1 className="text-lg font-semibold text-gray-900">Vault</h1>
+            <p className="text-xs text-gray-500">
+              {vaultProjects.length} idee{vaultProjects.length !== 1 ? "ën" : ""} in de wacht
+            </p>
+          </div>
+        </div>
+        <div className="relative">
+          <Search className="absolute left-3 top-1/2 -translate-y-1/2 w-3.5 h-3.5 text-gray-400" />
+          <input
+            type="text"
+            value={query}
+            onChange={(e) => setQuery(e.target.value)}
+            placeholder="Zoeken..."
+            className="pl-8 pr-3 py-1.5 text-sm border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-indigo-400 w-48"
+          />
+        </div>
+      </div>
+
+      {/* Grid */}
+      <div className="flex-1 overflow-y-auto px-6 py-4">
+        {filtered.length === 0 ? (
+          <div className="flex flex-col items-center justify-center h-48 text-center">
+            <Package className="w-10 h-10 text-gray-300 mb-3" />
+            <p className="text-sm font-medium text-gray-500">
+              {query ? "Geen resultaten" : "Vault is leeg"}
+            </p>
+            <p className="text-xs text-gray-400 mt-1">
+              {query
+                ? "Probeer een andere zoekterm"
+                : 'Maak een nieuw project aan met startfase "Vault" om ideeën te bewaren'}
+            </p>
+          </div>
+        ) : (
+          <div className="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
+            {filtered.map((project) => {
+              if (!project) return null;
+              const cleanDesc = stripPhaseMarker(project.description ?? "");
+              return (
+                <div
+                  key={project.id}
+                  className="bg-white border border-gray-200 rounded-xl p-4 flex flex-col gap-3 hover:border-gray-300 hover:shadow-sm transition-all"
+                >
+                  <div className="flex items-start justify-between gap-2">
+                    <div className="flex-1 min-w-0">
+                      <p className="text-sm font-semibold text-gray-900 truncate">{project.name}</p>
+                      <p className="text-xs text-gray-400 mt-0.5 font-mono">{project.identifier}</p>
+                    </div>
+                    <span className="shrink-0 inline-flex items-center gap-1 px-1.5 py-0.5 rounded text-[10px] font-medium bg-gray-100 text-gray-600">
+                      <span className="w-1.5 h-1.5 rounded-full bg-gray-400" />
+                      {PHASES.vault.shortLabel}
+                    </span>
+                  </div>
+
+                  {cleanDesc && (
+                    <p className="text-xs text-gray-500 line-clamp-2">{cleanDesc}</p>
+                  )}
+
+                  <RivettaPhaseTimeline description={project.description ?? ""} />
+
+                  <div className="flex items-center justify-between mt-auto">
+                    <span className="text-[10px] text-gray-400">
+                      {project.created_at ? renderFormattedDate(project.created_at) : "—"}
+                    </span>
+                    <button
+                      onClick={() => handleStartDesign(project.id, project.name, project.description ?? "")}
+                      disabled={advancing === project.id}
+                      className="flex items-center gap-1 px-2.5 py-1 text-xs font-medium bg-indigo-600 text-white hover:bg-indigo-700 rounded-md transition-colors disabled:opacity-50"
+                    >
+                      {advancing === project.id ? (
+                        <Loader2 className="w-3 h-3 animate-spin" />
+                      ) : (
+                        <ChevronRight className="w-3 h-3" />
+                      )}
+                      Start Design
+                    </button>
+                  </div>
+                </div>
+              );
+            })}
+          </div>
+        )}
+      </div>
+    </div>
+  );
+});
+
+export default VaultPage;
