@@ -0,0 +1,47 @@
+import { parsePhase, PHASES, ProjectPhase } from "@/helpers/rivetta/phase";
+
+interface BadgeProps {
+  description: string;
+  className?: string;
+  phase?: ProjectPhase;
+}
+
+export function RivettaPhaseBadge({ description, className = "", phase: forcedPhase }: BadgeProps) {
+  const phase = forcedPhase ?? parsePhase(description);
+  const cfg = PHASES[phase];
+  return (
+    <span
+      className={`inline-flex items-center gap-1 px-1.5 py-0.5 rounded text-[10px] font-medium ${cfg.bgClass} ${cfg.textClass} ${className}`}
+    >
+      <span className={`w-1.5 h-1.5 rounded-full shrink-0 ${cfg.dotClass}`} />
+      {cfg.shortLabel}
+    </span>
+  );
+}
+
+export function RivettaPhaseTimeline({ description }: { description: string }) {
+  const current = parsePhase(description);
+  const visible: ProjectPhase[] = [
+    "vault", "design_s1", "design_s2", "design_s3",
+    "preproduction", "production", "release", "marketing",
+  ];
+  const activeIdx = visible.indexOf(current);
+  return (
+    <div className="flex items-center gap-0.5 w-full">
+      {visible.map((phase, idx) => {
+        const cfg = PHASES[phase];
+        const done = idx < activeIdx;
+        const active = idx === activeIdx;
+        return (
+          <div
+            key={phase}
+            title={cfg.label}
+            className={`h-1 flex-1 rounded-full transition-all ${
+              active ? cfg.dotClass : done ? "bg-indigo-300" : "bg-gray-200"
+            }`}
+          />
+        );
+      })}
+    </div>
+  );
+}
diff --git a/apps/web/core/components/rivetta/phase-controls.tsx b/apps/web/core/components/rivetta/phase-controls.tsx
new file mode 100644
index 0000000..6e82d75
--- /dev/null
+++ b/apps/web/core/components/rivetta/phase-controls.tsx
@@ -0,0 +1,141 @@
+import { useState } from "react";
+import { observer } from "mobx-react";
+import { useParams } from "next/navigation";
+import { ChevronRight, Loader2, Archive, Megaphone } from "lucide-react";
+import type { IProject } from "@plane/types";
+import { TOAST_TYPE, setToast } from "@plane/propel/toast";
+import { parsePhase, getNextPhase, encodePhase, stripPhaseMarker, PHASES } from "@/helpers/rivetta/phase";
+import { useProject } from "@/hooks/store/use-project";
+import { ProjectPageService } from "@/services/page/project-page.service";
+import { RivettaPhaseBadge, RivettaPhaseTimeline } from "./phase-badge";
+import { RivettaHandoffModal } from "./handoff-modal";
+
+const pageService = new ProjectPageService();
+
+interface Props {
+  project: IProject;
+}
+
+export const RivettaPhaseControls = observer(function RivettaPhaseControls({ project }: Props) {
+  const [advancing, setAdvancing] = useState(false);
+  const [showHandoff, setShowHandoff] = useState(false);
+
+  const { workspaceSlug } = useParams<{ workspaceSlug: string }>();
+  const { updateProject } = useProject();
+
+  const phase = parsePhase(project.description ?? "");
+  const nextPhase = getNextPhase(phase);
+
+  const handleAdvance = async () => {
+    if (!nextPhase || !workspaceSlug) return;
+    if (phase === "production") {
+      setShowHandoff(true);
+      return;
+    }
+    setAdvancing(true);
+    try {
+      const newDesc = encodePhase(nextPhase, stripPhaseMarker(project.description ?? ""));
+      await updateProject(workspaceSlug, project.id, { description: newDesc });
+      setToast({ type: TOAST_TYPE.SUCCESS, title: "Fase bijgewerkt", message: `Project staat nu in: ${PHASES[nextPhase].label}` });
+    } catch {
+      setToast({ type: TOAST_TYPE.ERROR, title: "Fout", message: "Fase-overgang mislukt" });
+    } finally {
+      setAdvancing(false);
+    }
+  };
+
+  const handleArchive = async () => {
+    if (!workspaceSlug) return;
+    if (!confirm(`"${project.name}" archiveren?`)) return;
+    try {
+      const newDesc = encodePhase("archived", stripPhaseMarker(project.description ?? ""));
+      await updateProject(workspaceSlug, project.id, { description: newDesc });
+      setToast({ type: TOAST_TYPE.SUCCESS, title: "Gearchiveerd", message: project.name });
+    } catch {
+      setToast({ type: TOAST_TYPE.ERROR, title: "Fout", message: "Archiveren mislukt" });
+    }
+  };
+
+  const handleHandoffConfirm = async (briefing: string, checkedItems: string[]) => {
+    if (!workspaceSlug) return;
+    setAdvancing(true);
+
+    const today = new Date().toLocaleDateString("nl-NL", { day: "numeric", month: "long", year: "numeric" });
+    const checklistHtml = checkedItems.map((item) => `<li>✅ ${item}</li>`).join("");
+    const descriptionHtml = `
+      <h2>Handover — ${project.name}</h2>
+      <p><strong>Datum:</strong> ${today}</p>
+      <h3>Checklist afgerond</h3>
+      <ul>${checklistHtml}</ul>
+      ${briefing.trim() ? `<h3>Toelichting voor Marketing &amp; Sales</h3><p>${briefing.replace(/\n/g, "<br/>")}</p>` : ""}
+    `.trim();
+
+    const newDesc = encodePhase("release", stripPhaseMarker(project.description ?? ""));
+
+    await Promise.all([
+      pageService.create(workspaceSlug, project.id, {
+        name: `Handover briefing — ${today}`,
+        description_html: descriptionHtml,
+        access: 0,
+      }),
+      updateProject(workspaceSlug, project.id, { description: newDesc }),
+    ]);
+
+    setToast({ type: TOAST_TYPE.SUCCESS, title: "Handover voltooid", message: "Project staat nu in Release-fase" });
+    setShowHandoff(false);
+    setAdvancing(false);
+  };
+
+  const phaseCfg = PHASES[phase];
+
+  return (
+    <>
+      <div className="flex flex-col gap-2 p-3 rounded-lg border border-gray-200 bg-gray-50">
+        <div className="flex items-center justify-between gap-2">
+          <div className="flex items-center gap-2">
+            <span className="text-xs font-medium text-gray-500">Fase</span>
+            <RivettaPhaseBadge description={project.description ?? ""} />
+          </div>
+          <div className="flex items-center gap-1">
+            {nextPhase && (
+              <button
+                onClick={handleAdvance}
+                disabled={advancing}
+                title={`Naar ${PHASES[nextPhase].label}`}
+                className="flex items-center gap-1 px-2 py-1 text-xs font-medium bg-indigo-600 text-white hover:bg-indigo-700 rounded-md transition-colors disabled:opacity-50"
+              >
+                {advancing ? (
+                  <Loader2 className="w-3 h-3 animate-spin" />
+                ) : phase === "production" ? (
+                  <Megaphone className="w-3 h-3" />
+                ) : (
+                  <ChevronRight className="w-3 h-3" />
+                )}
+                {PHASES[nextPhase].shortLabel}
+              </button>
+            )}
+            {phase !== "archived" && (
+              <button
+                onClick={handleArchive}
+                title="Archiveren"
+                className="p-1 text-gray-400 hover:text-gray-700 hover:bg-gray-200 rounded transition-colors"
+              >
+                <Archive className="w-3.5 h-3.5" />
+              </button>
+            )}
+          </div>
+        </div>
+        <RivettaPhaseTimeline description={project.description ?? ""} />
+        <p className="text-[10px] text-gray-400">{phaseCfg.label}</p>
+      </div>
+
+      {showHandoff && (
+        <RivettaHandoffModal
+          projectName={project.name}
+          onConfirm={handleHandoffConfirm}
+          onCancel={() => { setShowHandoff(false); setAdvancing(false); }}
+        />
+      )}
+    </>
+  );
+});
