diff --git a/apps/web/core/services/docmost.service.ts b/apps/web/core/services/docmost.service.ts
new file mode 100644
index 0000000..b999d70
--- /dev/null
+++ b/apps/web/core/services/docmost.service.ts
@@ -0,0 +1,99 @@
+const DOCMOST_URL = (import.meta.env.VITE_DOCMOST_API_URL as string | undefined) ?? "";
+const DOCMOST_TOKEN = (import.meta.env.VITE_DOCMOST_API_TOKEN as string | undefined) ?? "";
+
+interface DocmostSpace {
+  id: string;
+  name: string;
+  slug: string;
+}
+
+interface DocmostPage {
+  id: string;
+  title: string;
+}
+
+interface PaginatedResponse<T> {
+  items?: T[];
+  data?: { items?: T[] } | T[];
+}
+
+/**
+ * Converts a Plane project identifier (e.g. "RIVETTA") to a Docmost-compatible
+ * space slug: lowercase, alphanumeric only, 2–50 characters.
+ */
+export function toDocmostSlug(identifier: string): string {
+  const slug = identifier.toLowerCase().replace(/[^a-z0-9]/g, "").slice(0, 50);
+  return slug.length >= 2 ? slug : slug.padEnd(2, "x");
+}
+
+class DocmostService {
+  get isConfigured(): boolean {
+    return !!DOCMOST_URL && !!DOCMOST_TOKEN;
+  }
+
+  /** Public Docmost base URL — used to build iframe src. */
+  get baseUrl(): string {
+    return DOCMOST_URL;
+  }
+
+  private async post<T>(path: string, body: unknown = {}): Promise<T> {
+    const res = await fetch(`${DOCMOST_URL}/api${path}`, {
+      method: "POST",
+      headers: {
+        "Content-Type": "application/json",
+        Authorization: `Bearer ${DOCMOST_TOKEN}`,
+      },
+      body: JSON.stringify(body),
+    });
+    if (!res.ok) {
+      const text = await res.text().catch(() => res.statusText);
+      throw new Error(`Docmost ${path} — ${res.status}: ${text}`);
+    }
+    return res.json() as Promise<T>;
+  }
+
+  private async listSpaces(): Promise<DocmostSpace[]> {
+    const data = await this.post<PaginatedResponse<DocmostSpace>>("/spaces/", {
+      page: 1,
+      limit: 200,
+    });
+    if (Array.isArray(data)) return data;
+    if (Array.isArray(data.items)) return data.items;
+    const nested = data.data;
+    if (Array.isArray(nested)) return nested;
+    if (nested && Array.isArray((nested as { items?: DocmostSpace[] }).items))
+      return (nested as { items: DocmostSpace[] }).items;
+    return [];
+  }
+
+  async ensureSpace(name: string, slug: string): Promise<DocmostSpace> {
+    const spaces = await this.listSpaces();
+    const existing = spaces.find((s) => s.slug === slug);
+    if (existing) return existing;
+    return this.post<DocmostSpace>("/spaces/create", { name, slug });
+  }
+
+  async createPage(spaceId: string, title: string, contentHtml?: string): Promise<DocmostPage> {
+    return this.post<DocmostPage>("/pages/create", {
+      spaceId,
+      title,
+      ...(contentHtml ? { content: contentHtml, format: "html" } : {}),
+    });
+  }
+
+  /**
+   * Ensures the project's Docmost space exists, then creates a page in it.
+   * Intended as a best-effort call — callers should .catch(() => {}).
+   */
+  async ensureSpaceAndCreatePage(
+    projectName: string,
+    projectSlug: string,
+    pageTitle: string,
+    contentHtml?: string
+  ): Promise<DocmostPage> {
+    const space = await this.ensureSpace(projectName, projectSlug);
+    return this.createPage(space.id, pageTitle, contentHtml);
+  }
+}
+
+export const docmostService = new DocmostService();
