diff --git a/apps/web/core/components/rivetta/phase-chip.tsx b/apps/web/core/components/rivetta/phase-chip.tsx
new file mode 100644
index 0000000..1348e8e
--- /dev/null
+++ b/apps/web/core/components/rivetta/phase-chip.tsx
@@ -0,0 +1,162 @@
+import { useState } from "react";
+import { observer } from "mobx-react";
+import { ChevronDown, Archive, Megaphone, ChevronRight } from "lucide-react";
+import { Button } from "@plane/propel/button";
+import { IconButton } from "@plane/propel/icon-button";
+import { Pill, EPillSize } from "@plane/propel/pill";
+import { Popover } from "@plane/propel/popover";
+import { TOAST_TYPE, setToast } from "@plane/propel/toast";
+import { cn } from "@plane/utils";
+import { parsePhase, getNextPhase, encodePhase, stripPhaseMarker, PHASES } from "@/helpers/rivetta/phase";
+import { useProject } from "@/hooks/store/use-project";
+import { ProjectPageService } from "@/services/page/project-page.service";
+import { RivettaPhaseTimeline } from "./phase-badge";
+import { RivettaHandoffModal } from "./handoff-modal";
+
+const pageService = new ProjectPageService();
+
+interface Props {
+  projectId: string;
+  workspaceSlug: string;
+}
+
+export const RivettaPhaseChip = observer(function RivettaPhaseChip({ projectId, workspaceSlug }: Props) {
+  const [advancing, setAdvancing] = useState(false);
+  const [showHandoff, setShowHandoff] = useState(false);
+
+  const { getPartialProjectById, updateProject } = useProject();
+  const project = getPartialProjectById(projectId);
+
+  if (!project) return null;
+
+  const phase = parsePhase(project.description ?? "");
+  const nextPhase = getNextPhase(phase);
+  const cfg = PHASES[phase];
+
+  const handleAdvance = async () => {
+    if (!nextPhase) return;
+    if (phase === "production") {
+      setShowHandoff(true);
+      return;
+    }
+    setAdvancing(true);
+    try {
+      const newDesc = encodePhase(nextPhase, stripPhaseMarker(project.description ?? ""));
+      await updateProject(workspaceSlug, project.id, { description: newDesc });
+      setToast({ type: TOAST_TYPE.SUCCESS, title: "Fase bijgewerkt", message: PHASES[nextPhase].label });
+    } catch {
+      setToast({ type: TOAST_TYPE.ERROR, title: "Fout", message: "Fase-overgang mislukt" });
+    } finally {
+      setAdvancing(false);
+    }
+  };
+
+  const handleArchive = async () => {
+    if (!confirm(`"${project.name}" archiveren?`)) return;
+    try {
+      const newDesc = encodePhase("archived", stripPhaseMarker(project.description ?? ""));
+      await updateProject(workspaceSlug, project.id, { description: newDesc });
+      setToast({ type: TOAST_TYPE.SUCCESS, title: "Gearchiveerd", message: project.name });
+    } catch {
+      setToast({ type: TOAST_TYPE.ERROR, title: "Fout", message: "Archiveren mislukt" });
+    }
+  };
+
+  const handleHandoffConfirm = async (briefing: string, checkedItems: string[]) => {
+    setAdvancing(true);
+    const today = new Date().toLocaleDateString("nl-NL", { day: "numeric", month: "long", year: "numeric" });
+    const checklistHtml = checkedItems.map((item) => `<li>✅ ${item}</li>`).join("");
+    const descriptionHtml = `
+      <h2>Handover — ${project.name}</h2>
+      <p><strong>Datum:</strong> ${today}</p>
+      <h3>Checklist afgerond</h3>
+      <ul>${checklistHtml}</ul>
+      ${briefing.trim() ? `<h3>Toelichting voor Marketing &amp; Sales</h3><p>${briefing.replace(/\n/g, "<br/>")}</p>` : ""}
+    `.trim();
+    const newDesc = encodePhase("release", stripPhaseMarker(project.description ?? ""));
+    await Promise.all([
+      pageService.create(workspaceSlug, project.id, {
+        name: `Handover briefing — ${today}`,
+        description_html: descriptionHtml,
+        access: 0,
+      }),
+      updateProject(workspaceSlug, project.id, { description: newDesc }),
+    ]);
+    setToast({ type: TOAST_TYPE.SUCCESS, title: "Handover voltooid", message: "Project staat nu in Release-fase" });
+    setShowHandoff(false);
+    setAdvancing(false);
+  };
+
+  return (
+    <>
+      <Popover>
+        <Popover.Button
+          className={cn(
+            "flex items-center gap-1 rounded-md border px-2 py-1 text-11 font-medium transition-colors",
+            cfg.bgClass, cfg.textClass, "border-transparent hover:opacity-80"
+          )}
+        >
+          <span className={cn("h-1.5 w-1.5 rounded-full shrink-0", cfg.dotClass)} />
+          {cfg.shortLabel}
+          <ChevronDown className="h-3 w-3 opacity-60" />
+        </Popover.Button>
+
+        <Popover.Panel
+          side="bottom"
+          align="start"
+          className="z-50 w-64 rounded-lg border border-subtle bg-surface-1 p-3 shadow-raised-200"
+        >
+          <div className="flex flex-col gap-3">
+            {/* Phase header */}
+            <div className="flex items-center justify-between gap-2">
+              <div className="flex items-center gap-1.5">
+                <span className={cn("h-2 w-2 rounded-full shrink-0", cfg.dotClass)} />
+                <span className="text-13 font-medium text-primary">{cfg.label}</span>
+              </div>
+              {phase !== "archived" && (
+                <IconButton
+                  variant="ghost"
+                  size="sm"
+                  icon={Archive}
+                  onClick={handleArchive}
+                  title="Archiveren"
+                />
+              )}
+            </div>
+
+            {/* Timeline */}
+            <RivettaPhaseTimeline description={project.description ?? ""} />
+
+            {/* Advance button */}
+            {nextPhase && (
+              <Button
+                variant="tertiary"
+                size="sm"
+                className="w-full justify-center"
+                onClick={handleAdvance}
+                disabled={advancing}
+                prependIcon={
+                  advancing
+                    ? undefined
+                    : phase === "production"
+                      ? <Megaphone />
+                      : <ChevronRight />
+                }
+              >
+                {advancing ? "..." : `Naar ${PHASES[nextPhase].shortLabel}`}
+              </Button>
+            )}
+          </div>
+        </Popover.Panel>
+      </Popover>
+
+      {showHandoff && (
+        <RivettaHandoffModal
+          projectName={project.name}
+          onConfirm={handleHandoffConfirm}
+          onCancel={() => { setShowHandoff(false); setAdvancing(false); }}
+        />
+      )}
+    </>
+  );
+});
