+# ─── Docmost integration ─────────────────────────────────────────────────────
+# Add these to Plane's .env.local (or wherever you set Vite env vars).
+
+# Public URL of your Docmost instance, as seen by the browser.
+# With the nginx config, this is the /docs subpath of your Plane domain.
+VITE_DOCMOST_API_URL=https://plane.rivetta.eu/docs
+
+# Long-lived admin API token from Docmost.
+# Create one in Docmost → Settings → API Tokens.
+# This token is used to auto-create spaces and pages on phase transitions.
+# NOTE: This value is visible in the browser bundle — acceptable for internal tools.
+VITE_DOCMOST_API_TOKEN=your-docmost-admin-token-here
+
+# ─── Docmost server settings (used in docker-compose.docmost.yml) ─────────────
+DOCMOST_APP_URL=https://plane.rivetta.eu/docs
+DOCMOST_APP_SECRET=generate-a-random-64-char-secret-here
+DOCMOST_DB_USER=docmost
+DOCMOST_DB_PASS=change-this-password
+DOCMOST_DB_NAME=docmost
diff --git a/deploy/nginx-docmost.conf b/deploy/nginx-docmost.conf
new file mode 100644
index 0000000..532b4a8
--- /dev/null
+++ b/deploy/nginx-docmost.conf
@@ -0,0 +1,48 @@
+# Nginx config snippet — add inside your existing server {} block for plane.rivetta.eu
+# This proxies /docs/* to Docmost so both apps share the same origin (same-origin
+# cookie = single login, iframe works without cross-origin restrictions).
+
+server {
+    listen 443 ssl http2;
+    server_name plane.rivetta.eu;
+
+    # --- Plane (existing) ---
+    location / {
+        proxy_pass         http://127.0.0.1:8080;
+        proxy_set_header   Host              $host;
+        proxy_set_header   X-Real-IP         $remote_addr;
+        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
+        proxy_set_header   X-Forwarded-Proto $scheme;
+    }
+
+    # --- Docmost wiki ---
+    # Matches /docs and /docs/* — proxied to Docmost running on port 3001.
+    # The trailing slash in proxy_pass strips the /docs prefix so Docmost
+    # sees requests at / (its expected root).
+    location /docs/ {
+        proxy_pass         http://127.0.0.1:3001/;
+        proxy_set_header   Host              $host;
+        proxy_set_header   X-Real-IP         $remote_addr;
+        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
+        proxy_set_header   X-Forwarded-Proto $scheme;
+
+        # Required for Docmost's real-time collaboration (WebSocket)
+        proxy_http_version 1.1;
+        proxy_set_header   Upgrade    $http_upgrade;
+        proxy_set_header   Connection "upgrade";
+
+        # Docmost sets cookies without a path — rewrite them to /docs/
+        # so the browser sends them only for Docmost requests.
+        proxy_cookie_path  / /docs/;
+    }
+
+    # Redirect bare /docs to /docs/ so relative links inside Docmost work
+    location = /docs {
+        return 301 /docs/;
+    }
+
+    # SSL certs (Let's Encrypt / certbot)
+    ssl_certificate     /etc/letsencrypt/live/plane.rivetta.eu/fullchain.pem;
+    ssl_certificate_key /etc/letsencrypt/live/plane.rivetta.eu/privkey.pem;
+    include             /etc/letsencrypt/options-ssl-nginx.conf;
+}
