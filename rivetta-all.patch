diff --git a/apps/web/core/components/docmost/wiki-iframe.tsx b/apps/web/core/components/docmost/wiki-iframe.tsx
new file mode 100644
index 0000000..23b9f2a
--- /dev/null
+++ b/apps/web/core/components/docmost/wiki-iframe.tsx
@@ -0,0 +1,147 @@
+import { useState, useEffect } from "react";
+import { BookOpen, Loader2, ExternalLink } from "lucide-react";
+import { cn } from "@plane/utils";
+import { docmostService, toDocmostSlug } from "@/services/docmost.service";
+
+interface WikiIframeProps {
+  /** Full URL to load in the iframe — e.g. DOCMOST_URL + "/s/my-space" */
+  src: string;
+  /** Page <title> for accessibility */
+  title?: string;
+  className?: string;
+  /** When set, the service will silently ensure this space exists on mount */
+  ensureSpace?: { name: string; identifier: string };
+}
+
+export function WikiIframe({ src, title = "Wiki", className, ensureSpace }: WikiIframeProps) {
+  const [loaded, setLoaded] = useState(false);
+  const docmostUrl = docmostService.baseUrl;
+
+  // Silently provision the space so the first load finds it already there
+  useEffect(() => {
+    if (!ensureSpace || !docmostService.isConfigured) return;
+    const slug = toDocmostSlug(ensureSpace.identifier);
+    docmostService.ensureSpace(ensureSpace.name, slug).catch(() => {});
+  }, [ensureSpace?.identifier]); // eslint-disable-line react-hooks/exhaustive-deps
+
+  if (!docmostUrl) {
+    return (
+      <div className={cn("flex h-full items-center justify-center bg-surface-1", className)}>
+        <div className="flex flex-col items-center gap-3 text-center">
+          <div className="flex h-12 w-12 items-center justify-center rounded-xl bg-layer-3">
+            <BookOpen className="h-6 w-6 text-placeholder" />
+          </div>
+          <div>
+            <p className="text-13 font-semibold text-primary">Wiki niet geconfigureerd</p>
+            <p className="mt-1 text-11 text-placeholder max-w-[260px]">
+              Stel <code className="rounded bg-layer-3 px-1 py-0.5 font-mono text-10">VITE_DOCMOST_API_URL</code> in
+              je <code className="rounded bg-layer-3 px-1 py-0.5 font-mono text-10">.env.local</code> in om Docmost te
+              verbinden.
+            </p>
+          </div>
+        </div>
+      </div>
+    );
+  }
+
+  return (
+    <div className={cn("relative h-full w-full", className)}>
+      {/* Loading overlay — fades out once iframe signals it has loaded */}
+      {!loaded && (
+        <div className="absolute inset-0 z-10 flex items-center justify-center bg-surface-1">
+          <div className="flex flex-col items-center gap-3">
+            <Loader2 className="h-6 w-6 animate-spin text-placeholder" />
+            <p className="text-11 text-placeholder">Wiki laden…</p>
+          </div>
+        </div>
+      )}
+
+      {/* "Open in new tab" escape hatch — dimmed by default, full opacity on hover */}
+      <a
+        href={src}
+        target="_blank"
+        rel="noopener noreferrer"
+        title="Open in Docmost"
+        className="absolute right-3 top-3 z-20 flex items-center gap-1 rounded-md border border-subtle bg-surface-1 px-2 py-1 text-11 text-placeholder opacity-40 transition-opacity hover:opacity-100 focus:opacity-100"
+      >
+        <ExternalLink className="h-3 w-3" />
+        Docmost
+      </a>
+
+      <iframe
+        src={src}
+        title={title}
+        className="h-full w-full border-0"
+        allow="clipboard-read; clipboard-write"
+        onLoad={() => setLoaded(true)}
+      />
+    </div>
+  );
+}
+
+/**
+ * Variant used on the workspace-level wiki page.
+ * Points to the Docmost workspace root so users see all spaces.
+ */
+export function WorkspaceWikiIframe({ className }: { className?: string }) {
+  const docmostUrl = docmostService.baseUrl;
+  return (
+    <WikiIframe
+      src={docmostUrl ? `${docmostUrl}/spaces` : ""}
+      title="Workspace Wiki"
+      className={className}
+    />
+  );
+}
+
+/**
+ * Variant used on the project Pages tab.
+ * Deep-links to the project's dedicated Docmost space.
+ */
+interface ProjectWikiIframeProps {
+  projectName: string;
+  projectIdentifier: string;
+  className?: string;
+}
+
+export function ProjectWikiIframe({ projectName, projectIdentifier, className }: ProjectWikiIframeProps) {
+  const docmostUrl = docmostService.baseUrl;
+  const slug = toDocmostSlug(projectIdentifier);
+
+  if (!docmostUrl) {
+    return <WikiIframe src="" title="Project Wiki" className={className} />;
+  }
+
+  return (
+    <WikiIframe
+      src={`${docmostUrl}/s/${slug}`}
+      title={`${projectName} — Wiki`}
+      className={className}
+      ensureSpace={{ name: projectName, identifier: projectIdentifier }}
+    />
+  );
+}
+
+/**
+ * Small inline badge that links to the project's Docmost space.
+ * Used in page headers alongside RivettaPhaseBadge.
+ */
+export function DocmostSpaceLink({ projectName, projectIdentifier }: { projectName: string; projectIdentifier: string }) {
+  const docmostUrl = docmostService.baseUrl;
+  if (!docmostUrl) return null;
+  const slug = toDocmostSlug(projectIdentifier);
+  return (
+    <a
+      href={`${docmostUrl}/s/${slug}`}
+      target="_blank"
+      rel="noopener noreferrer"
+      className="flex items-center gap-1 rounded border border-subtle px-1.5 py-0.5 text-11 text-placeholder hover:text-secondary hover:border-strong transition-colors"
+    >
+      <BookOpen className="h-3 w-3" />
+      Wiki
+      <ExternalLink className="h-2.5 w-2.5 opacity-60" />
+    </a>
+  );
+}
+
+WikiIframe.displayName = "WikiIframe";
