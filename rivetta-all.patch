+# Docmost wiki — add this to your existing Plane docker-compose setup
+# Usage: docker compose -f docker-compose.yml -f deploy/docker-compose.docmost.yml up -d
+
+services:
+  docmost:
+    image: docmost/docmost:latest
+    depends_on:
+      - docmost_db
+      - docmost_redis
+    environment:
+      APP_URL: "${DOCMOST_APP_URL:-https://docs.rivetta.eu}"
+      APP_SECRET: "${DOCMOST_APP_SECRET}"
+      DATABASE_URL: "postgresql://${DOCMOST_DB_USER:-docmost}:${DOCMOST_DB_PASS:-docmost}@docmost_db:5432/${DOCMOST_DB_NAME:-docmost}"
+      REDIS_URL: "redis://docmost_redis:6379"
+    ports:
+      - "127.0.0.1:3001:3000"
+    volumes:
+      - docmost_storage:/app/data/storage
+    restart: unless-stopped
+    networks:
+      - plane_network
+      - docmost_network
+
+  docmost_db:
+    image: postgres:16-alpine
+    environment:
+      POSTGRES_DB: "${DOCMOST_DB_NAME:-docmost}"
+      POSTGRES_USER: "${DOCMOST_DB_USER:-docmost}"
+      POSTGRES_PASSWORD: "${DOCMOST_DB_PASS:-docmost}"
+    volumes:
+      - docmost_postgres:/var/lib/postgresql/data
+    restart: unless-stopped
+    networks:
+      - docmost_network
+
+  docmost_redis:
+    image: redis:7-alpine
+    restart: unless-stopped
+    networks:
+      - docmost_network
+
+volumes:
+  docmost_storage:
+  docmost_postgres:
+
+networks:
+  plane_network:
+    external: true
+  docmost_network:
+    internal: true
